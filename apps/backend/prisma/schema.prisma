generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DepartmentEnum {
  Engineering
  Product
  Design
  Data
  QA
  DevOps
  Security
}

enum EmpTypeEnum {
  FullTime
  PartTime
  Contract
  Freelance
  Internship
}

enum ExpLevelEnum {
  Intern
  Fresher
  Junior
  MidLevel
  Senior
  Leader
  Manager
}

enum LocationEnum {
  HaNoi
  HoChiMinh
  HaiPhong
  DaNang
  Hue
  CanTho
  ThaiNguyen
  PhuTho
  LaoCai
  TuyenQuang
  LaiChau
  DienBien
  SonLa
  QuangNinh
  HungYen
  NinhBinh
  ThanhHoa
  NgheAn
  HaTinh
  QuangBinh
  QuangTri
  QuangNam
  QuangNgai
  KhanhHoa
  GiaLai
  DakLak
  LamDong
  DongNai
  BaRiaVungTau
  TayNinh
  LongAn
  DongThap
  AnGiang
  KienGiang
  CaMau
}

enum QuestionTypeEnum {
  Technical
  Behavioral
  Scenario
}

model Company {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String           @unique @db.VarChar(255)
  description String           @db.Text
  jobs        JobDescription[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("companies")
}

model JobDescription {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Recruitment Information
  jobTitle        String         @map("job_title") @db.VarChar(255)
  department      DepartmentEnum
  experienceLevel ExpLevelEnum   @map("experience_level")
  employmentType  EmpTypeEnum    @map("employment_type")
  location        LocationEnum
  companyId       String         @map("company_id") @db.Uuid
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requiredSkills  String[]       @map("required_skills")
  benefits        String[]       @default([])

  // AI Generated Result
  aboutCompanyGenerated String   @map("about_company_generated") @db.Text
  jobSummaryGenerated   String   @map("job_summary_generated") @db.Text
  responsibilities      String[] @map("responsibilities") // at least 5
  requirementsGenerated String[] @map("requirements_generated") // at least 5
  niceToHaveGenerated   String[] @map("nice_to_have_generated") // at least 3

  interviewQuestions InterviewQuestion[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("job_descriptions")
}

model InterviewQuestion {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobDescriptionId String         @map("job_description_id") @db.Uuid
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  type         QuestionTypeEnum
  questionText String           @map("question_text") @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")

  @@map("interview_questions")
}
